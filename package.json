{
  "name": "linkr",
  "version": "0.0.0",
  "private": true,
  "description": "Linkr — a privacy-first, real-time, end-to-end encrypted messaging platform (MERN + TypeScript).",
  "license": "UNLICENSED",
  "engines": {
    "node": ">=20",
    "pnpm": ">=9"
  },
  "scripts": {
    "dev": "pnpm --parallel --filter @linkr/server --filter @linkr/client dev",
    "dev:server": "pnpm --filter @linkr/server dev",
    "dev:client": "pnpm --filter @linkr/client dev",
    "build": "pnpm --filter @linkr/shared build && pnpm --filter @linkr/server build && pnpm --filter @linkr/client build",
    "typecheck": "pnpm --recursive --parallel typecheck",
    "lint": "pnpm --recursive --parallel --if-present lint",
    "clean": "pnpm --recursive --parallel exec rimraf dist node_modules/.cache"
  },
  "packageManager": "pnpm@11.8.0"
}
