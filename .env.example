# Server
PORT=5000
MONGODB_URI=
REDIS_URL=
JWT_ACCESS_SECRET=
JWT_REFRESH_SECRET=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Sprint 5 media storage. If set (cloudinary://<key>:<secret>@<cloud>), uploads go to Cloudinary
# and messages store the returned secure URL. If unset, the server falls back to LOCAL DISK
# (server/uploads/, git-ignored, outside the web root) served via an authenticated download route
# — so media works in dev without Cloudinary credentials. Media is encrypted in transit only.
CLOUDINARY_URL=
# Deprecated placeholder — real SMS OTP now uses MSG91 (see MSG91_AUTH_KEY below).
OTP_PROVIDER_KEY=
# MSG91 OTP widget — server-only Authkey used to verify the widget's access token. When set,
# onboarding uses real SMS OTP; when unset, the built-in dev OTP flow is used (devCode hint).
# Get it from your MSG91 dashboard. NEVER expose this to the client.
MSG91_AUTH_KEY=
# Optional: 32+ char secret to derive the phone encryption/HMAC keys (blueprint §4).
# If unset, the server derives keys from JWT_ACCESS_SECRET so no extra setup is required.
PHONE_ENC_KEY=

# Phase 3 calls — WebRTC ICE (STUN/TURN). In dev, STUN alone usually connects peers on the same
# network. For calls across strict NATs/mobile data you need a TURN relay (e.g. coturn).
# STUN_URLS: comma-separated; leave blank to use Google's public STUN by default.
STUN_URLS=
# TURN_URLS: comma-separated, e.g. turn:turn.yourdomain.com:3478,turns:turn.yourdomain.com:5349
TURN_URLS=
# TURN_SECRET: coturn `static-auth-secret`. The server mints short-lived per-user credentials from
# it (TURN REST API). NEVER expose this to the client — it is used server-side only.
TURN_SECRET=
# TURN_TTL: lifetime in seconds of minted TURN credentials (default 3600).
TURN_TTL=3600
# Dev/test only: the auto-replying @linkr_bot account for testing chat without a second
# login. Defaults ON in development; set to "false" to disable. NEVER enabled in production
# (the server force-disables it when NODE_ENV=production) and must be off before real E2EE.
ENABLE_TEST_BOT=true
CLIENT_URL=http://localhost:5173

# Client (VITE_ prefix)
VITE_API_URL=http://localhost:5000
VITE_GOOGLE_CLIENT_ID=
# MSG91 OTP widget (public values, safe to ship to the browser). Set BOTH to enable real SMS OTP
# in onboarding; leave blank to use the built-in dev OTP flow. Pair with MSG91_AUTH_KEY above.
VITE_MSG91_WIDGET_ID=
VITE_MSG91_WIDGET_TOKEN=
